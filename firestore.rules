rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile and status rules
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Administrator');
      
      // User nested sub-collections: subjects, flashcards, exams, sessions, etc.
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Administrator');
      }
    }
    
    // AI Cache access: read by authenticated users, written by authenticated users or admins
    match /ai_cache/{cacheId} {
      allow read, write: if request.auth != null;
    }
    
    // AI Usage quotas: read/write by owners and admins
    match /ai_usage/{usageId} {
      allow read, write: if request.auth != null && (usageId.startsWith(request.auth.uid) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Administrator');
    }

    // AI Logs: create by auth users, full access by administrators
    match /ai_logs/{logId} {
      allow create: if request.auth != null;
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Administrator';
    }

    // Error telemetry logs: create by auth users, view by administrators
    match /error_logs/{logId} {
      allow create: if request.auth != null;
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Administrator';
    }

    // Global in-app notifications
    match /notifications/{notifId} {
      allow read, write: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        resource.data.isAdmin == true || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Administrator'
      );
      allow create: if request.auth != null;
    }

    // Activity logging
    match /activity_log/{logId} {
      allow read, write: if request.auth != null;
    }

    // Welcome email logs
    match /emailLogs/{logId} {
      allow create: if true;
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Administrator';
    }
  }
}
